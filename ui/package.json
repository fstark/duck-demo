{
  "name": "duck-demo-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mcp-app": "npm run build:mcp-app:generic-confirm && npm run build:mcp-app:item-inspect",
    "build:mcp-app:generic-confirm": "MCP_APP_ENTRY=generic-confirm.html vite build --mode mcp-app",
    "build:mcp-app:item-inspect": "MCP_APP_ENTRY=item-inspect.html vite build --mode mcp-app",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --max-warnings=0"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^0.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.160.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.12",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vite-plugin-singlefile": "^2.0.2"
  }
}